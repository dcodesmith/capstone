    "# ============================\n",
    "# WEEK 11 Configuration\n",
    "# ============================\n",
    "#\n",
    "# NEW APPROACH: Use surrogate models (GradientBoosting, KNN, Poly2)\n",
    "# informed by classmate's LOO-CV analysis showing which works best.\n",
    "#\n",
    "# F1: GradientBoosting (low RMSE)\n",
    "# F2: GradientBoosting (handles non-linearity)\n",
    "# F3: GradientBoosting (captures local patterns)\n",
    "# F4: Poly2 (polynomial trend)\n",
    "# F5: KNN (local neighborhood effective)\n",
    "# F6: Poly2 (smooth trends)\n",
    "# F7: KNN (local neighborhood effective)\n",
    "# F8: Poly2 (near-linear per classmate's analysis)\n",
    "\n",
    "surrogate_map = {\n",
    "    1: \"gradientboost\",\n",
    "    2: \"gradientboost\",\n",
    "    3: \"gradientboost\",\n",
    "    4: \"poly2\",\n",
    "    5: \"knn\",\n",
    "    6: \"kmeans\",  # K-means clustering to find best region\n",
    "    7: \"knn\",\n",
    "    8: \"poly2\",\n",
    "}\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(f\"WEEK {n_rounds + 1} QUERIES (Surrogate Model Strategy)\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "for i in range(1, 9):\n",
    "    # 1. Load initial data\n",
    "    X_init = np.load(DATA_DIR / f\"function_{i}\" / \"initial_inputs.npy\")\n",
    "    y_init = np.load(DATA_DIR / f\"function_{i}\" / \"initial_outputs.npy\")\n",
    "\n",
    "    X = X_init.copy()\n",
    "    y = y_init.copy()\n",
    "\n",
    "    # 2. Append every round's (x, y) for this function\n",
    "    for r in range(n_rounds):\n",
    "        x_prev = np.array(inputs_rounds[r][i - 1])\n",
    "        y_prev = float(outputs_rounds[r][i - 1])\n",
    "        X = np.vstack([X, x_prev.reshape(1, -1)])\n",
    "        y = np.append(y, y_prev)\n",
    "\n",
    "    print(f\"\\nFunction {i}: {len(y)} total points\")\n",
    "\n",
    "    # 3. Best point so far\n",
    "    best_idx = np.argmax(y)\n",
    "    best_point = X[best_idx]\n",
    "    best_y_so_far = y[best_idx]\n",
    "\n",
    "    # 4. Use surrogate model to suggest next point\n",
    "    model_type = surrogate_map[i]\n",
    "    \n",
    "    if model_type == \"kmeans\":\n",
    "        # Special case: K-means clustering for F6\n",
    "        best_x, cluster_id = suggest_kmeans_cluster_point(X, y, n_clusters=3)\n",
    "        strategy = f\"K-Means clustering (best cluster: {cluster_id})\"\n",
    "    else:\n",
    "        best_x, model = suggest_surrogate_point(\n",
    "            X, y,\n",
    "            model_type=model_type,\n",
    "            resolution=0.05,\n",
    "            random_state=40 + i,\n",
    "        )\n",
    "        strategy = f\"Surrogate ({model_type}) grid search\"\n",
    "\n",
    "    # 5. Format query\n",
    "    query_str = \"-\".join(f\"{v:.6f}\" for v in best_x)\n",
    "\n",
    "    # 6. Duplicate check\n",
    "    is_duplicate = np.any(np.all(np.isclose(X, best_x, atol=1e-4), axis=1))\n",
    "    if is_duplicate:\n",
    "        print(\"  ⚠️ WARNING: Suggested query is a DUPLICATE!\")\n",
    "\n",
    "    # 7. Report\n",
    "    print(f\"  Strategy: {strategy}\")\n",
    "    print(f\"  Best y so far: {best_y_so_far:.6f}\")\n",
    "    print(f\"  New query: {query_str}\")"
   ]
  }
