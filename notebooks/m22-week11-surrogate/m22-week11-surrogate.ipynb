    "import numpy as np\n",
    "from pathlib import Path\n",
    "import warnings\n",
    "\n",
    "from sklearn.gaussian_process import GaussianProcessRegressor\n",
    "from sklearn.gaussian_process.kernels import RBF, Matern, WhiteKernel\n",
    "from sklearn.ensemble import GradientBoostingRegressor\n",
    "from sklearn.neighbors import KNeighborsRegressor\n",
    "from sklearn.preprocessing import PolynomialFeatures\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.pipeline import make_pipeline\n",
    "from sklearn.exceptions import ConvergenceWarning\n",
    "warnings.filterwarnings(\"ignore\", category=ConvergenceWarning)\n",
    "\n",
    "DATA_DIR = Path(\"..\") / \"initial_data\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "surrogate_suggest",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ======================================\n",
    "# WEEK 11 NEW: Surrogate Model Suggestion\n",
    "# ======================================\n",
    "# Instead of GP-UCB, fit a surrogate model and find\n",
    "# the point with highest prediction via grid search.\n",
    "#\n",
    "# Models:\n",
    "# - GradientBoosting: good for non-linear, handles interactions\n",
    "# - KNN: good for local patterns\n",
    "# - Poly2: good for smooth quadratic trends\n",
    "\n",
    "def suggest_surrogate_point(\n",
    "    X,\n",
    "    y,\n",
    "    model_type=\"gradientboost\",\n",
    "    resolution=0.05,\n",
    "    random_state=0,\n",
    "):\n",
    "    \"\"\"\n",
    "    Fit a surrogate model, predict on a grid, return point with max prediction.\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    X : np.ndarray (N, d)\n",
    "    y : np.ndarray (N,)\n",
    "    model_type : str\n",
    "        'gradientboost', 'knn', or 'poly2'\n",
    "    resolution : float\n",
    "        Grid resolution (smaller = finer but slower)\n",
    "    random_state : int\n",
    "    \n",
    "    Returns\n",
    "    -------\n",
    "    best_x : np.ndarray (d,)\n",
    "    model : fitted model\n",
    "    \"\"\"\n",
    "    d = X.shape[1]\n",
    "    \n",
    "    # Build model\n",
    "    if model_type == \"gradientboost\":\n",
    "        model = GradientBoostingRegressor(\n",
    "            n_estimators=100,\n",
    "            max_depth=3,\n",
    "            random_state=random_state\n",
    "        )\n",
    "    elif model_type == \"knn\":\n",
    "        k = min(5, len(X) - 1)  # Can't have more neighbors than points\n",
    "        model = KNeighborsRegressor(n_neighbors=k)\n",
    "    elif model_type == \"poly2\":\n",
    "        model = make_pipeline(\n",
    "            PolynomialFeatures(degree=2),\n",
    "            LinearRegression()\n",
    "        )\n",
    "    else:\n",
    "        raise ValueError(f\"Unknown model_type: {model_type}\")\n",
    "    \n",
    "    # Fit model\n",
    "    model.fit(X, y)\n",
    "    \n",
    "    # Generate grid candidates\n",
    "    # For high dimensions, use coarser grid to avoid memory issues\n",
    "    if d <= 3:\n",
    "        res = resolution\n",
    "    elif d <= 5:\n",
    "        res = 0.1\n",
    "    else:\n",
    "        res = 0.15\n",
    "    \n",
    "    grids = [np.arange(0, 1 + res, res) for _ in range(d)]\n",
    "    mesh = np.meshgrid(*grids, indexing='ij')\n",
    "    candidates = np.column_stack([m.ravel() for m in mesh])\n",
    "    \n",
    "    # Predict at all candidates\n",
    "    predictions = model.predict(candidates)\n",
    "    \n",
    "    # Find best\n",
    "    best_idx = np.argmax(predictions)\n",
    "    best_x = candidates[best_idx]\n",
    "    \n",
    "    return best_x, model"
   ]
  },
  {
